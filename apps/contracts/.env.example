# The private key of the account to use for deployments.
# IMPORTANT: DO NOT USE A KEY THAT HOLDS REAL FUNDS.
# ⚠️  NEVER commit this file with real values to version control

PRIVATE_KEY=

# The mnemonic phrase that derives the same wallet as PRIVATE_KEY.
# Required by scripts/seed-submissions.ts to derive 3 verifier signers
# at HD paths m/44'/60'/0'/0/{1,2,3} from this exact mnemonic. The
# deployer pre-funds each derived verifier with ~0.1 CELO so they can
# vote on the seeded submissions.
DEPLOYER_MNEMONIC=

# (Optional) The API key for Etherscan V2 to verify your contracts.
# Get yours from https://etherscan.io/
ETHERSCAN_API_KEY=

# (Optional) Set to "true" to enable the gas reporter.
REPORT_GAS=


# RPC URLs (optional, defaults provided in hardhat.config.ts)
CELO_RPC_URL=https://forno.celo.org
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org/
