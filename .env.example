# Web app (apps/web/.env.local)
#
# WalletConnect cloud project id — used by RainbowKit for connector metadata.
# Free at https://cloud.reown.com — required for non-MiniPay wallet connections.
NEXT_PUBLIC_WC_PROJECT_ID=

# Deployed PriceOracle proxy address per network. Filled after running
# `pnpm contracts:deploy:celo-sepolia` and `pnpm contracts:deploy:celo`.
NEXT_PUBLIC_PRICE_ORACLE_ADDRESS_MAINNET=
NEXT_PUBLIC_PRICE_ORACLE_ADDRESS_SEPOLIA=

# cUSD on Celo Sepolia. Mainnet cUSD is hardcoded in lib/contracts.ts.
NEXT_PUBLIC_CUSD_ADDRESS_SEPOLIA=

# Vercel Blob server token — required by /api/submissions to store receipt
# photos. Auto-injected when the Blob integration is added to the Vercel
# project. For local dev, generate one in the Vercel dashboard or use a
# separate test store.
BLOB_READ_WRITE_TOKEN=


# Contracts (apps/contracts/.env)
#
# Deployer key. Use a DEDICATED hot wallet — never your personal funds.
PRIVATE_KEY=

# Celo Sepolia cUSD address to wire into the proxy at deploy time
# (passed via the CUSD_ADDRESS env var to scripts/deploy.ts).
CUSD_ADDRESS=

# Celoscan API key for `pnpm contracts:verify`.
ETHERSCAN_API_KEY=

# After deploy, set this to the proxy address before running
# `pnpm contracts:seed:celo-sepolia` (or `:celo`).
PROXY_ADDRESS=

# Reward pool size to seed (in cUSD, default 50).
# SEED_AMOUNT=50

# Gas reporter switch (optional).
# REPORT_GAS=true
