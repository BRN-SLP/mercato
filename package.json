{
  "name": "mercato",
  "version": "0.2.0",
  "description": "Mercato — crowdsourced consumer price basket on Celo. A community-built, on-chain cost-of-living index.",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "type-check": "turbo type-check",
    "contracts:compile": "turbo run compile --filter=hardhat",
    "contracts:test": "turbo run test --filter=hardhat",
    "contracts:deploy": "turbo run deploy --filter=hardhat",
    "contracts:deploy:celo-sepolia": "turbo run deploy:celo-sepolia --filter=hardhat",
    "contracts:deploy:celo": "turbo run deploy:celo --filter=hardhat",
    "contracts:seed:celo-sepolia": "turbo run seed:celo-sepolia --filter=hardhat",
    "contracts:seed:celo": "turbo run seed:celo --filter=hardhat",
    "contracts:seed-mercato:celo-sepolia": "turbo run seed-mercato:celo-sepolia --filter=hardhat",
    "contracts:seed-mercato:celo": "turbo run seed-mercato:celo --filter=hardhat",
    "sdk:build": "pnpm --filter @mercato/sdk build"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "turbo": "^1.10.16",
    "typescript": "^5.2.2"
  },
  "packageManager": "pnpm@8.10.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
